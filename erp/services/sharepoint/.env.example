# =============================================================================
# GE ERP — SharePoint Service environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development                     # development | production

# ─── Azure AD / MSAL ─────────────────────────────────────────────────────────
# From your Azure AD App Registration (GE-ERP-SharePoint)
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-here

# ─── SharePoint / Microsoft Graph ────────────────────────────────────────────
# Retrieve once via Graph Explorer:
#   GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/GE-ERP
#   GET https://graph.microsoft.com/v1.0/sites/{siteId}/drives
SHAREPOINT_SITE_ID=your-graph-site-id-here
SHAREPOINT_DRIVE_ID=your-graph-drive-id-here

# Root folder path within the drive (no leading slash, no trailing slash)
SHAREPOINT_BASE_PATH=GE-ERP/Purchase

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ge_user:password@localhost:5432/ge_erp

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your ERP frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,https://your-erp.company.com

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=25                      # Files >4 MB use Graph upload sessions automatically
